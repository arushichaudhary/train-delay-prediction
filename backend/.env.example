# Copy this file to .env and fill in real values. Never commit the real .env.

# Used to sign JWT tokens. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
VELORA_SECRET_KEY=replace-with-a-random-64-char-hex-string

# Get a free key at https://aistudio.google.com/app/apikey
# If left blank, the chatbot falls back to a rule-based reply (still works,
# just not LLM-generated).
GEMINI_API_KEY=
